+#[derive(Debug, Clone)]
+pub struct HistoryOverlay {
+    /// Filtered history entries, newest first. The renderer paints
+    /// items[0..min(items.len(), max_visible_rows)] in order.
+    /// Empty `items` is allowed (renderer no-ops) but the caller
