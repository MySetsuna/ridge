{
  "name": "ridge",
  "version": "0.0.6",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:remote": "vite build --config vite.remote.config.js",
    "build:desktop-web": "node scripts/build-desktop-web.mjs",
    "build:flag-font": "node scripts/build-flag-font.mjs",
    "sync:cloud-controller": "node scripts/sync-cloud-desktop-app.mjs",
    "sync:signaling": "node scripts/sync-signaling.mjs",
    "dev:remote": "node scripts/start-remote-dev.mjs",
    "build:remote-server": "cargo build --release --bin remote-server --manifest-path src-tauri/Cargo.toml",
    "build:remote-server:dev": "cargo build --bin remote-server --manifest-path src-tauri/Cargo.toml",
    "build:teammate-shim": "cargo build --release --bin tmux --manifest-path src-tauri/Cargo.toml && node scripts/copy-teammate-shim.mjs",
    "build:cli": "cargo build --release -p ridge-cli",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:build": "pnpm tauri build && node scripts/post-build-rename.mjs",
    "tauri:build:debug": "node scripts/tauri-build-debug.mjs",
    "tauri:dev:cdp": "node scripts/tauri-dev-cdp.mjs",
    "tauri:dev:with-cloud": "node scripts/tauri-dev-with-cloud.mjs",
    "cdp:smoke": "node scripts/cdp-smoke.mjs",
    "cdp:pty": "node scripts/cdp-pty-parsers.mjs",
    "cdp:pane-graph": "node scripts/cdp-pane-graph.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "e2e:shell": "wdio run wdio.conf.ts",
    "e2e:perf": "wdio run wdio.perf.conf.ts",
    "perf-bench": "pwsh scripts/perf-bench.ps1",
    "perf:compare": "pwsh scripts/perf-compare.ps1",
    "perf:frame": "pwsh scripts/perf-frame-compare.ps1",
    "clean": "rimraf node_modules/.vite build target src-tauri/target",
    "dev:cloud": "RIDGE_CLOUD_BASE_DOMAIN=localhost:5001 pnpm dev",
    "dev:remote:cloud": "RIDGE_CLOUD_BASE_DOMAIN=localhost:5001 pnpm dev:remote",
    "dev:with-cloud": "RIDGE_CLOUD_BASE_DOMAIN=localhost:5001 bash scripts/dev-with-cloud.sh",
    "dev:all": "RIDGE_CLOUD_BASE_DOMAIN=localhost:5001 bash scripts/start-all.sh"
  },
  "license": "MIT",
  "dependencies": {
    "@gitgraph/js": "^1.4.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@ridge/split": "workspace:*",
    "@ridge/term-wasm": "link:packages/ridge-term/pkg",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "lucide-svelte": "^1.0.1",
    "marked": "^15.0.7",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "overlayscrollbars": "^2.15.1",
    "qrcode": "^1.5.4",
    "svelte-dnd-action": "^0.9.69",
    "svelte-splitpanes": "^8.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@vitest/coverage-v8": "^4.1.4",
    "@wdio/cli": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "chai": "^6.2.2",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "svelte": "^5.55.9",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.4",
    "webdriverio": "^9.27.1",
    "workbox-window": "^7.4.1"
  }
}
