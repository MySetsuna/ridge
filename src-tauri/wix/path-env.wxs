<?xml version="1.0" encoding="UTF-8"?>
<!--
  Appends [INSTALLDIR] to the current user's PATH so `tmux` (the Ridge shim)
  is resolvable from any shell, not only Ridge's own PTY panes.

  System="no" targets HKCU (matches the NSIS installer hook).
  Part="last" Action="set" = append (non-destructive) and Permanent="no" = remove on uninstall.

  KeyPath is a RegistryValue so the component has a real uninstall anchor.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Fragment>
        <DirectoryRef Id="INSTALLDIR">
            <Component Id="RidgePathEnvVar_0_1_0" Guid="A4970075-EECD-520B-6EF3-590E5B33506E">
                <RegistryValue Root="HKCU"
                               Key="Software\tauri-app\ridge_0_1_0"
                               Name="RidgePathEnv_0_1_0"
                               Type="integer"
                               Value="1"
                               KeyPath="yes" />
                <Environment Id="RidgePathEnv_0_1_0"
                             Name="PATH"
                             Value="[INSTALLDIR]"
                             Permanent="no"
                             Part="last"
                             Action="set"
                             System="no" />
            </Component>
        </DirectoryRef>
    </Fragment>
</Wix>
