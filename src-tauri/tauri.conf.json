{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ridge",
  "version": "0.0.2",
  "identifier": "com.tauri-app.ridge",
  "build": {
    "beforeDevCommand": "node packages/ridge-term/build.mjs --dev && node scripts/ensure-teammate-shim.mjs && npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "node packages/ridge-term/build.mjs && npm run build && pnpm build:mobile",
    "beforeBundleCommand": "node -e \"setTimeout(()=>process.exit(0),3000)\" && cargo build --release --bin tmux --manifest-path src-tauri/Cargo.toml",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../ridge.theme": "ridge.theme",
      "../static/mobile": "static/mobile"
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["wix/path-env.wxs"],
        "componentRefs": ["RidgePathEnvVar_0_0_2"]
      }
    }
  }
}
