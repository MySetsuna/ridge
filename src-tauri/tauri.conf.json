{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wind",
  "version": "0.1.0",
  "identifier": "com.tauri-app.wind",
  "build": {
    "beforeDevCommand": "node scripts/ensure-teammate-shim.mjs && npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "cargo build --release --bin tmux --manifest-path src-tauri/Cargo.toml",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "wind",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["wix/path-env.wxs"],
        "componentRefs": ["WindPathEnvVar"]
      }
    }
  }
}