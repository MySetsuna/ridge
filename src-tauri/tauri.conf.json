{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ridge",
  "version": "0.0.2",
  "identifier": "com.tauri-app.ridge",
  "build": {
    "beforeDevCommand": "node scripts/ensure-teammate-shim.mjs && npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "node packages/ridge-term/build.mjs && npm run build",
    "beforeBundleCommand": "cargo build --release --bin tmux --manifest-path src-tauri/Cargo.toml",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ridge",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; img-src 'self' asset: https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: https://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "../ridge.theme"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["wix/path-env.wxs"],
        "componentRefs": ["RidgePathEnvVar_0_0_2"]
      }
    }
  }
}
