{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wind",
  "version": "0.1.0",
  "identifier": "com.tauri-app.wind",
  "build": {
    "beforeDevCommand": "node scripts/ensure-teammate-shim.mjs && npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "cargo build --release --bin tmux --manifest-path src-tauri/Cargo.toml",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "wind",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": {
      "target/release/tmux.exe": "./tmux.exe"
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
