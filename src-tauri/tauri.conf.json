{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ridge",
  "version": "0.0.10",
  "identifier": "com.tauri-app.ridge",
  "build": {
    "beforeDevCommand": "node packages/ridge-term/build.mjs --dev && node scripts/ensure-teammate-shim.mjs && node scripts/start-vite-dev.mjs",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "node packages/ridge-term/build.mjs && pnpm run build && pnpm build:remote && pnpm build:desktop-web",
    "beforeBundleCommand": "node -e \"setTimeout(()=>process.exit(0),3000)\" && cargo build --release --bin tmux --manifest-path src-tauri/Cargo.toml && pnpm build:cli",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ridge"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../ridge.theme": "ridge.theme",
      "../static/remote": "static/remote",
      "../web-remote-dist": "web-remote-dist"
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["wix/path-env.wxs"],
        "componentRefs": ["RidgePathEnvVar_0_0_2"]
      }
    }
  }
}
