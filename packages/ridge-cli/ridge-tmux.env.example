# ridge-tmux.service 的环境配置示例。
#
# 安装为 /etc/ridge/tmux.env（系统级）或 ~/.config/ridge/tmux.env（用户级），
# 权限 0600。ridge-cli tmux 经 clap 的 env fallback 读取这些变量
# （优先级：命令行参数 > 这里的环境变量 > 内置默认）。
#
#   sudo install -m 0600 -o ridge -g ridge ridge-tmux.env.example /etc/ridge/tmux.env

# 鉴权 token（必填，强烈建议）。每个 /api/v1/tmux/* 请求须带
# `x-ridge-token:` 或 `Authorization: Bearer`。留空/不设则引擎每次启动随机生成
# 并打印到 journald（agent 须从日志里抄）——固定下来才方便 systemd 常驻。
# 生成：openssl rand -hex 32
RIDGE_TMUX_TOKEN=

# 监听地址。默认 127.0.0.1（仅本机回环，最安全）。
# agent 与引擎同机时保持默认即可。跨机访问（0.0.0.0）须自行加 firewall/反代，
# 并务必设置上面的强 token——引擎对会话子进程无路径沙箱。
RIDGE_TMUX_BIND=127.0.0.1

# 监听端口。默认 0 = 由系统随机分配（端口写进启动日志）。
# 设固定端口方便 agent 侧写死 RIDGE_TEAMMATE_URL。
RIDGE_TMUX_PORT=47615
